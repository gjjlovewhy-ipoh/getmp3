import requests
from bs4 import BeautifulSoup
import time
import os
import urllib3

BASE_URL = "https://pan.vma.cc/pan/index.php"
HEADERS = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
}
START_PAGE = 1
END_PAGE = 10
OUTPUT_PATH = "mp3_links.txt"
urllib3.disable_warnings()

def crawl_single_page(page):
    try:
        params = {"page": page, "kw": ".mp3"}
        resp = requests.get(BASE_URL, params=params, headers=HEADERS, timeout=12, verify=False)
        resp.encoding = "utf-8"
        soup = BeautifulSoup(resp.text, "lxml")
        res = []
        for tag in soup.find_all(attrs={"onclick": True}):
            onclick = tag.get("onclick", "")
            if "copyToClipboard" not in onclick:
                continue
            arr = onclick.split("'")
            if len(arr) < 2:
                continue
            link = arr[1].strip()
            if link.lower().endswith(".mp3"):
                res.append(link)
        print(f"第{page}页：{len(res)} 条")
        return res
    except Exception as e:
        print(f"第{page}页异常：{str(e)}")
        return []

def main():
    all_links = []
    for p in range(START_PAGE, END_PAGE + 1):
        all_links.extend(crawl_single_page(p))
        time.sleep(1)
    # 去重
    all_links = sorted(list(set(all_links)))
    with open(OUTPUT_PATH, "w", encoding="utf-8") as f:
        f.write("=== MP3 自动抓取外链列表 ===\n")
        f.write(f"总数：{len(all_links)} 条\n\n")
        for url in all_links:
            f.write(url + "\n")
    print(f"完成！共 {len(all_links)} 条已写入 {OUTPUT_PATH}")

if __name__ == "__main__":
    main()
